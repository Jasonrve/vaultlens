{
  "name": "vaultlens",
  "version": "0.3.2",
  "description": "VaultLens - HashiCorp Vault UI",
  "type": "module",
  "scripts": {
    "predev": "node scripts/predev.mjs",
    "dev": "tsx watch --clear-screen=false src/server/server.ts",
    "build": "npm run build:client && npm run build:server && npm run copy-templates",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.json",
    "copy-templates": "node -e \"const fs=require('fs'),path=require('path');const src=path.join('src','server','templates');const dst=path.join('dist','server','templates');if(fs.existsSync(src)){fs.cpSync(src,dst,{recursive:true});console.log('[build] Templates copied to dist/server/templates')}else{console.log('[build] Templates directory not found, skipping copy')}\"",
    "start": "node dist/server/server.js",
    "lint": "eslint src/client",
    "preview": "vite preview"
  },
  "keywords": [],
  "license": "GPL-3.0-only",
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xyflow/react": "^12.10.1",
    "axios": "1.15.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "marked": "^18.0.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "openpgp": "^6.1.1",
    "prom-client": "^15.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.7.3",
    "vite": "8.0.8",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/hpp": "^0.2.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.10.1",
    "@typescript-eslint/parser": "^8.10.1",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2"
  }
}
