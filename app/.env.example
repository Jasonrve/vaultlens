# Server Configuration
PORT=3001
NODE_ENV=development

# Vault Configuration
VAULT_ADDR=http://127.0.0.1:8200

# System token — used for sharing and branding storage (use 'root' for local dev)
VAULT_SYSTEM_TOKEN=root

# Kubernetes auth — only needed when running in Kubernetes (replaces VAULT_SYSTEM_TOKEN)
# VAULT_K8S_AUTH_ROLE=vaultlens
# VAULT_K8S_AUTH_MOUNT defaults to: kubernetes
# VAULT_K8S_TOKEN_PATH defaults to: /var/run/secrets/kubernetes.io/serviceaccount/token

# Optional: Allow external CORS origins (comma-separated)
# CORS_ORIGIN=http://localhost:3000

# TLS Configuration
VAULT_SKIP_TLS_VERIFY=false

# Rate limiting (applied to /api/* routes only)
# RATE_LIMIT_MAX=500
# RATE_LIMIT_WINDOW_MS=900000
# SHARING_RATE_LIMIT_MAX=20

# Audit log path
# VAULT_AUDIT_LOG_PATH=/var/log/vault/audit.log

# Configuration storage backend: 'file' (default) or 'vault'
# 'file' stores config in a config.ini file on disk (default)
# 'vault' stores config in a Vault KV v2 engine named 'vaultlens-conf'
# VAULTLENS_CONFIG_STORAGE=file

# Path for file-based config storage (only used when VAULTLENS_CONFIG_STORAGE=file)
# VAULTLENS_CONFIG_PATH=/data/vaultlens

# Path for backup storage
# VAULTLENS_BACKUP_PATH=/data/backups
