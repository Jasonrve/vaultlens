# VaultLens development environment — use with docker-compose
# Copy to app/.env or set in your shell

# Vault connection
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=root

# VaultLens server
PORT=3001
NODE_ENV=development

# Optional: system token for merge operations (same as root in dev)
VAULT_SYSTEM_TOKEN=root

# TLS (not needed for dev Vault)
VAULT_SKIP_TLS_VERIFY=false
