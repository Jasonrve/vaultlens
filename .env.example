# VaultLens Configuration
# Copy this file to .env and adjust values

# Required: Vault server address
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# Required: System token for secure merge and shared secrets
VAULT_SYSTEM_TOKEN=your-vault-system-token

# Optional: Port to expose VaultLens
VAULTLENS_PORT=3001

# Optional: Skip TLS verification (NOT recommended for production)
VAULT_SKIP_TLS_VERIFY=false

# Optional: CORS origin (leave empty for same-origin)
CORS_ORIGIN=
